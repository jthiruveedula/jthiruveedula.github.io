---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Jagadeesh Thiruveedula">
  <section class="relative min-h-screen py-20 overflow-hidden bg-gradient-to-br from-slate-950 via-blue-950 to-indigo-950 text-white">
    <!-- Background Accents -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-indigo-500 rounded-full blur-3xl"></div>
    </div>

    <div class="container relative z-10 mx-auto px-4 max-w-4xl">
      <div class="text-center mb-16 animate-fade-in">
        <h1 class="text-5xl md:text-6xl font-black mb-6 bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-300">
          Let's Build the Future
        </h1>
        <p class="text-xl text-slate-300">
          Interested in GenAI architecture, GCP modernization, or high-scale data engineering? Let's connect.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Contact Channels -->
        <div class="space-y-6 animate-fade-in" style="animation-delay: 0.1s">
          <div>
            <h3 class="text-sm font-bold text-blue-300 uppercase tracking-widest mb-4">Direct Channels</h3>
            <div class="space-y-4">
              <a href="https://www.linkedin.com/in/jagadeesh-thiruveedula/" target="_blank" rel="noopener" class="flex items-center gap-4 group p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-blue-400/50 hover:bg-white/10 transition-all">
                <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-slate-400">LinkedIn</div>
                  <div class="font-semibold">Jagadeesh Thiruveedula</div>
                </div>
              </a>
              
              <a href="https://github.com/jthiruveedula" target="_blank" rel="noopener" class="flex items-center gap-4 group p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-blue-400/50 hover:bg-white/10 transition-all">
                <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-slate-400">GitHub</div>
                  <div class="font-semibold">@jthiruveedula</div>
                </div>
              </a>
            </div>
          </div>

          <div class="pt-6">
            <h3 class="text-sm font-bold text-blue-300 uppercase tracking-widest mb-4">Key Expertise</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-blue-500/20 text-blue-300 text-xs font-semibold rounded-full">GCP</span>
              <span class="px-3 py-1 bg-purple-500/20 text-purple-300 text-xs font-semibold rounded-full">GenAI</span>
              <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs font-semibold rounded-full">BigQuery</span>
              <span class="px-3 py-1 bg-green-500/20 text-green-300 text-xs font-semibold rounded-full">RAG</span>
              <span class="px-3 py-1 bg-blue-500/20 text-blue-300 text-xs font-semibold rounded-full">LLMs</span>
              <span class="px-3 py-1 bg-purple-500/20 text-purple-300 text-xs font-semibold rounded-full">Vector DBs</span>
            </div>
          </div>
        </div>

        <!-- Professional Summary Card -->
        <div class="card bg-white/5 border-white/10 p-8 backdrop-blur-xl animate-fade-in" style="animation-delay: 0.2s">
          <h3 class="text-2xl font-bold mb-4">Let's Collaborate</h3>
          <p class="text-slate-300 mb-6 leading-relaxed">
            With 10+ years driving enterprise data transformation and GenAI implementations, I specialize in:
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-sm">Cloud data platform modernization (AWS to GCP)</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-sm">RAG pipelines & LLM orchestration at scale</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-sm">Enterprise GenAI architecture & governance</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-sm">Cost optimization & performance tuning</span>
            </li>
          </ul>
          <div class="text-sm text-slate-400">
            <p>Available for consulting, advisory, and full-time opportunities.</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center animate-fade-in" style="animation-delay: 0.3s">
        <p class="text-lg text-slate-300 mb-6">
          Ready to transform your data infrastructure? Let's discuss how we can work together.
        </p>
        <a href="/experience" class="inline-block px-8 py-4 bg-white text-blue-950 font-bold rounded-full shadow-lg hover:bg-slate-100 hover:scale-105 transition-all duration-300">
          View My Experience
        </a>
      </div>
    </div>
  </section>
</Layout>
