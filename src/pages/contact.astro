---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Jagadeesh Thiruveedula" navLabel="Jagadeesh Thiruveedula">
  <section class="relative min-h-screen overflow-hidden bg-slate-950 py-20 text-slate-100">
    <!-- Background Accents -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-96 h-96 bg-cyan-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-indigo-500 rounded-full blur-3xl"></div>
    </div>

    <div class="container relative z-10 mx-auto px-4 max-w-4xl">
      <div class="mb-16 text-center">
        <p class="section-eyebrow text-amber-300">CONTACT</p>
        <h1 class="mt-3 text-2xl font-bold text-white md:text-3xl">Let's Build the Future</h1>
        <p class="text-xs text-slate-400 md:text-sm">
          Interested in GenAI architecture, GCP modernization, or high-scale data engineering? Let's connect.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Contact Channels -->
        <div class="space-y-6">
          <div>
            <h3 class="font-mono text-[11px] uppercase tracking-[0.25em] text-indigo-300 mb-4">Direct Channels</h3>
            <div class="space-y-4">
              <a href="https://www.linkedin.com/in/jagadeesh-thiruveedula/" target="_blank" rel="noopener" class="flex items-center gap-4 group p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400/50 hover:bg-white/10 transition-all">
                <div class="w-12 h-12 rounded-xl bg-cyan-500/20 flex items-center justify-center text-cyan-400 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-slate-400">LinkedIn</div>
                  <div class="font-medium">Jagadeesh Thiruveedula</div>
                </div>
              </a>
              
              <a href="https://github.com/jthiruveedula" target="_blank" rel="noopener" class="flex items-center gap-4 group p-4 rounded-2xl bg-white/5 border border-white/10 hover:border-cyan-400/50 hover:bg-white/10 transition-all">
                <div class="w-12 h-12 rounded-xl bg-cyan-500/20 flex items-center justify-center text-cyan-400 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </div>
                <div>
                  <div class="text-xs text-slate-400">GitHub</div>
                  <div class="font-medium">@jthiruveedula</div>
                </div>
              </a>
            </div>
          </div>

          <div class="pt-6">
            <h3 class="font-mono text-[11px] uppercase tracking-[0.25em] text-cyan-300 mb-4">Key Expertise</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs font-semibold rounded-full">GCP</span>
              <span class="px-3 py-1 bg-cyan-500/20 text-cyan-300 text-xs font-semibold rounded-full">GenAI</span>
              <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs font-semibold rounded-full">BigQuery</span>
              <span class="px-3 py-1 bg-emerald-500/20 text-emerald-300 text-xs font-semibold rounded-full">RAG</span>
              <span class="px-3 py-1 bg-cyan-500/20 text-cyan-300 text-xs font-semibold rounded-full">LLMs</span>
              <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 text-xs font-semibold rounded-full">Vector DBs</span>
            </div>
          </div>
        </div>

        <!-- Session Card: pseudo-log of engagement flow -->
        <article class="rounded-3xl border border-slate-800/70 bg-slate-900/40 p-8 shadow-[0_10px_30px_rgba(2,6,23,0.35)] backdrop-blur-xl">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-2 h-2 rounded-full bg-emerald-400/60"></span>
            <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-emerald-400/60">Session: Initiate</span>
          </div>
          <div class="space-y-0 session-steps relative">
            <!-- Vertical connector line -->
            <div class="absolute left-[17px] top-3 bottom-3 w-px bg-slate-800/60 overflow-hidden">
              <div class="session-connector-fill absolute top-0 left-0 w-full bg-gradient-to-b from-indigo-500 via-cyan-400 to-emerald-400" style="height: 0%"></div>
            </div>
            {['Understand current stack', 'Map AI surfaces', 'Ship a governed POC'].map((step, i) => (
              <div class="session-step flex items-center gap-3 group py-2">
                <div class="relative z-10 w-8 h-8 rounded-full border border-slate-700/60 bg-slate-900 flex items-center justify-center shrink-0 transition-all duration-300 session-dot">
                  <span class="font-mono text-[10px] text-slate-500">0{i + 1}</span>
                </div>
                <span class="font-mono text-xs text-slate-400 group-hover:text-slate-200 transition-colors">{step}</span>
              </div>
            ))}
          </div>
          <div class="mt-6 pt-5 border-t border-slate-800/60">
            <p class="text-xs text-slate-400 leading-relaxed">
              With 10+ years driving enterprise data transformation and GenAI implementations.
            </p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-slate-700/50 text-slate-500 bg-slate-900/50">Cloud Modernization</span>
              <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-slate-700/50 text-slate-500 bg-slate-900/50">RAG & LLM Ops</span>
              <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-slate-700/50 text-slate-500 bg-slate-900/50">GenAI Governance</span>
              <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-slate-700/50 text-slate-500 bg-slate-900/50">Cost Optimization</span>
            </div>
            <p class="mt-4 text-xs text-slate-500">Available for consulting, advisory, and full-time opportunities.</p>
          </div>
        </article>
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <p class="text-sm text-slate-400 mb-6 md:text-base">
          Ready to transform your data infrastructure? Let's discuss how we can work together.
        </p>
        <a href="/experience" class="inline-flex items-center justify-center rounded-full bg-cyan-400 px-7 py-3 text-sm font-bold text-slate-950 transition-all duration-200 hover:bg-cyan-300">
          View My Experience
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const tlSession = gsap.timeline({
      scrollTrigger: {
        trigger: '.session-steps',
        start: 'top 75%',
        toggleActions: 'play none none none',
      }
    });

    // Connector line fills sequentially
    tlSession.to('.session-connector-fill', { height: '100%', duration: 0.8, ease: 'power2.inOut' }, 0);

    // Steps stagger in
    tlSession.fromTo('.session-step', { opacity: 0, x: -16 }, { opacity: 1, x: 0, stagger: 0.15, duration: 0.5, ease: 'power3.out' }, '-=0.6');

    // Dots glow as they appear
    tlSession.to('.session-dot', {
      borderColor: 'rgba(52,211,153,0.6)',
      stagger: 0.15,
      duration: 0.3,
    }, '-=0.6');

    // Magnetic effect on CTA
    const cta = document.querySelector('.contact-section a[href="/experience"]') as HTMLElement;
    if (cta) {
      cta.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = cta.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(cta, { x: x * 0.2, y: y * 0.2, duration: 0.3, ease: 'power2.out' });
      });
      cta.addEventListener('mouseleave', () => gsap.to(cta, { x: 0, y: 0, duration: 0.4, ease: 'power3.out' }));
    }
  }
</script>

<style>
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in {
      opacity: 1 !important;
      transform: none !important;
    }
    .session-step { opacity: 1 !important; transform: none !important; }
    .session-connector-fill { height: 100% !important; }
    .session-dot { border-color: rgba(52,211,153,0.6) !important; }
  }
</style>