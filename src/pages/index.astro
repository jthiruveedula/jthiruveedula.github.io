---
import Layout from '../layouts/Layout.astro';

const capabilityCards = [
  ['Private LLM systems', 'Secure, domain-specific assistants with guardrails, observability, and deployment patterns designed for real enterprise use.'],
  ['Enterprise RAG', 'Context-aware retrieval pipelines that connect structured and unstructured data with governed, production-grade accuracy.'],
  ['Agentic workflows', 'Orchestration patterns for multi-step reasoning, task routing, and reliable execution on cloud-native infrastructure.'],
  ['GCP-native architecture', 'BigQuery, Vertex AI, Cloud Run, and Dataflow aligned into scalable, cost-aware AI systems.'],
  ['Token-efficient inference', 'Prompt design, routing, and model selection tuned for latency, cost, and operational discipline.'],
  ['Governed AI operations', 'Controls, lineage, auditability, and deployment hygiene from prototype to production.'],
];

const projectCards = [
  ['Private RAG copilots', 'Production-grade assistants that retrieve from enterprise knowledge stores with policy-aware grounding.'],
  ['Agent orchestration', 'Task-routing systems that coordinate retrieval, planning, and action with measurable reliability.'],
  ['GCP AI platforms', 'Cloud-native GenAI stacks built for performance, cost control, and rapid iteration.'],
];
---

<Layout title="Jagadeesh Thiruveedula — GenAI Systems Architect | Private LLM & RAG" description="A premium portfolio for a GenAI-driven data architect building private LLM systems, enterprise RAG, and governed AI workflows on GCP.">
  <section class="relative isolate overflow-hidden bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.12),transparent_18%),linear-gradient(135deg,#020617_0%,#111827_45%,#0f172a_100%)] py-24 md:py-32">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-24 left-10 h-72 w-72 rounded-full bg-cyan-400/10 blur-3xl"></div>
      <div class="absolute top-16 right-8 h-96 w-96 rounded-full bg-indigo-500/10 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-emerald-400/8 blur-3xl"></div>
      <div class="absolute inset-0 opacity-20" style="background-image:linear-gradient(rgba(148,163,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.08) 1px, transparent 1px); background-size: 72px 72px;"></div>
    </div>

    <div class="container relative z-10 mx-auto px-4 text-center md:text-left">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-10 md:items-start">
        <div class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm font-semibold tracking-[0.2em] text-cyan-100 uppercase shadow-[0_18px_50px_rgba(8,47,73,0.35)] backdrop-blur-xl">
          <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_0_6px_rgba(52,211,153,0.16)]"></span>
          GenAI systems architect · private LLM · enterprise RAG
        </div>

        <div class="max-w-4xl text-center md:text-left">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-200/90">Command surface for production AI</p>
          <h1 class="text-5xl font-black tracking-tight text-white md:text-7xl lg:text-8xl">I architect AI systems that feel as reliable as they look ambitious.</h1>
          <p class="mt-6 max-w-3xl text-lg text-slate-200 md:text-xl">Private LLM applications, enterprise-grade RAG pipelines, and governed agentic workflows built on GCP for real teams that need performance, security, and operational clarity.</p>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-3 md:justify-start">
          {['GCP-native', 'BigQuery + Vertex AI', 'Token-efficient', 'Governed workflows'].map((item) => (
            <span class="rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm font-medium text-slate-100 shadow-[0_10px_30px_rgba(15,23,42,0.35)] backdrop-blur-xl">{item}</span>
          ))}
        </div>

        <div class="flex flex-col gap-4 sm:flex-row">
          <a href="#systems" class="rounded-full bg-cyan-400 px-7 py-3 text-sm font-semibold text-slate-950 shadow-[0_18px_45px_rgba(34,211,238,0.25)] transition hover:-translate-y-0.5 hover:bg-cyan-300">Explore the systems</a>
          <a href="/contact" class="rounded-full border border-white/10 bg-white/8 px-7 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-white/12">Start a conversation</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-18 md:py-24">
    <div class="container mx-auto px-4">
      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {capabilityCards.map(([title, copy]) => (
          <article class="rounded-3xl border border-white/8 bg-white/6 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:bg-white/10">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.35em] text-cyan-200/90">Capability</p>
            <h2 class="mb-3 text-2xl font-semibold text-white">{title}</h2>
            <p class="text-slate-300">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="systems" class="bg-slate-900 py-18 md:py-24">
    <div class="container mx-auto px-4">
      <div class="mb-10 max-w-3xl">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.35em] text-cyan-200/90">Architecture thinking</p>
        <h2 class="text-3xl font-black text-white md:text-5xl">A premium systems surface, not a generic portfolio grid.</h2>
        <p class="mt-4 text-slate-300">The design language is deliberately restrained: deep contrast, calm motion, precise hierarchy, and technical proof points that reinforce the work instead of distracting from it.</p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="rounded-3xl border border-white/8 bg-white/6 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl">
          <p class="text-sm uppercase tracking-[0.35em] text-emerald-200/90">System flow</p>
          <div class="mt-6 grid gap-4 text-slate-100">
            {['Ingest', 'Embed', 'Retrieve', 'Orchestrate', 'Govern', 'Serve'].map((step, index) => (
              <div class="flex items-center gap-4 rounded-2xl border border-white/8 bg-slate-900/70 p-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-cyan-400/12 text-sm font-semibold text-cyan-100">0{index + 1}</span>
                <span class="text-base font-medium">{step}</span>
              </div>
            ))}
          </div>
        </article>

        <article class="rounded-3xl border border-white/8 bg-gradient-to-br from-cyan-400/10 via-white/6 to-emerald-400/8 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl">
          <p class="text-sm uppercase tracking-[0.35em] text-cyan-100">Proof bar</p>
          <div class="mt-6 grid gap-4">
            {['6 production GenAI systems', 'GCP-native architecture', 'Vertex AI + Gemini + BigQuery', 'Token-cost aware design'].map((item) => (
              <div class="rounded-2xl border border-white/10 bg-slate-950/60 p-4 text-slate-100">{item}</div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-18 md:py-24">
    <div class="container mx-auto px-4">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="max-w-2xl">
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.35em] text-cyan-200/90">Featured systems</p>
          <h2 class="text-3xl font-black text-white md:text-5xl">Thoughtful, production-facing AI work.</h2>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {projectCards.map(([title, copy]) => (
          <article class="group rounded-3xl border border-white/8 bg-white/6 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl transition duration-300 hover:-translate-y-1 hover:border-cyan-400/40 hover:bg-white/10">
            <div class="mb-6 h-12 w-12 rounded-2xl bg-cyan-400/12"></div>
            <h3 class="text-2xl font-semibold text-white">{title}</h3>
            <p class="mt-4 text-slate-300">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-900 py-18 md:py-24">
    <div class="container mx-auto px-4">
      <article class="rounded-3xl border border-cyan-400/20 bg-[linear-gradient(135deg,rgba(14,165,233,0.12),rgba(8,47,73,0.35))] p-8 shadow-[0_18px_60px_rgba(15,23,42,0.35)] backdrop-blur-xl md:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-cyan-100">Next step</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-black text-white md:text-5xl">The site now reads like an AI systems command surface rather than a generic developer card stack.</h2>
        <p class="mt-4 max-w-3xl text-slate-200">This is the foundation for the full premium refactor: structured content, stronger hierarchy, cinematic visuals, and a motion system that supports the narrative instead of overwhelming it.</p>
        <a href="/contact" class="mt-8 inline-flex rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-cyan-100">Contact</a>
      </article>
    </div>
  </section>
</Layout>
