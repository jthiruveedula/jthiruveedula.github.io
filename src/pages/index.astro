---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jagadeesh Thiruveedula — Data Architect & GenAI Leader">
  <!-- Hero Section -->
  <section class="relative min-h-screen w-full bg-gradient-to-br from-blue-950 via-indigo-950 to-slate-900 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))]"></div>
    
    <div class="relative z-10 container mx-auto px-4 pt-32 pb-20 flex flex-col items-center text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-medium mb-8 animate-fade-in">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
        </span>
        Available for GenAI Architectural Advisory
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black text-white mb-6 tracking-tighter bg-clip-text text-transparent bg-gradient-to-b from-white to-slate-400">
        Jagadeesh Thiruveedula
      </h1>
      
      <h2 class="text-2xl md:text-3xl font-bold text-blue-400 mb-8 max-w-2xl mx-auto">
        Architecting the Future with GenAI & Cloud Data Platforms
      </h2>
      
      <p class="text-lg md:text-xl text-slate-400 mb-12 max-w-3xl leading-relaxed">
        10+ years of driving enterprise impact. Specialist in GCP modernization, RAG pipelines, and LLM orchestration at scale.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6">
        <a href="/experience" class="px-10 py-4 bg-blue-600 text-white font-bold rounded-full shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:bg-blue-500 transition-all transform hover:scale-105">
          View Experience
        </a>
        <a href="#genai-showcase" class="px-10 py-4 bg-slate-800 text-white font-bold rounded-full border border-slate-700 hover:bg-slate-700 transition-all transform hover:scale-105">
          GenAI Projects
        </a>
      </div>
    </div>
  </section>

  <!-- Impact Metrics -->
  <section class="py-24 bg-white dark:bg-slate-950 border-y border-slate-200 dark:border-slate-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
        <div class="flex flex-col items-center">
          <div class="text-5xl font-black text-blue-600 mb-2">25%+</div>
          <div class="text-slate-500 font-medium uppercase tracking-widest text-xs">Cost Reduction</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-5xl font-black text-indigo-600 mb-2">100TB+</div>
          <div class="text-slate-500 font-medium uppercase tracking-widest text-xs">Data Daily</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-5xl font-black text-purple-600 mb-2">99.9%</div>
          <div class="text-slate-500 font-medium uppercase tracking-widest text-xs">System Uptime</div>
        </div>
        <div class="flex flex-col items-center">
          <div class="text-5xl font-black text-blue-500 mb-2">50+</div>
          <div class="text-slate-500 font-medium uppercase tracking-widest text-xs">F500 Projects</div>
        </div>
      </div>
    </div>
  </section>

  <!-- GenAI Portfolio Section -->
  <section id="genai-showcase" class="py-24 bg-slate-50 dark:bg-slate-900/30">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-16">
        <h2 class="text-4xl font-bold text-slate-900 dark:text-white mb-4">GenAI & LLM Portfolio</h2>
        <p class="text-lg text-slate-600 dark:text-slate-400">Production-grade implementations of Retrieval Augmented Generation and autonomous agents.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Project 1 -->
        <div class="group bg-white dark:bg-slate-800 p-8 rounded-3xl border border-slate-200 dark:border-slate-700 hover:shadow-2xl transition-all">
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-2xl flex items-center justify-center mb-6 text-purple-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3 dark:text-white group-hover:text-blue-500 transition-colors">Pipeline Assistant</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">Automated dbt & Airflow code generation using Vertex AI Gemini models.</p>
          <div class="flex gap-2">
            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-[10px] font-bold rounded uppercase">LangChain</span>
            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-[10px] font-bold rounded uppercase">GCP</span>
          </div>
        </div>

        <!-- Project 2 -->
        <div class="group bg-white dark:bg-slate-800 p-8 rounded-3xl border border-slate-200 dark:border-slate-700 hover:shadow-2xl transition-all">
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center mb-6 text-blue-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3 dark:text-white group-hover:text-blue-500 transition-colors">RAG BQ Chatbot</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">Natural language interface for querying multi-terabyte BigQuery datasets with RAG.</p>
          <div class="flex gap-2">
            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-[10px] font-bold rounded uppercase">LlamaIndex</span>
            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-[10px] font-bold rounded uppercase">Vertex AI</span>
          </div>
        </div>

        <!-- Project 3 -->
        <div class="group bg-white dark:bg-slate-800 p-8 rounded-3xl border border-slate-200 dark:border-slate-700 hover:shadow-2xl transition-all">
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-2xl flex items-center justify-center mb-6 text-green-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3 dark:text-white group-hover:text-blue-500 transition-colors">LLM SQL Agent</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">Autonomous agent for SQL dialect migration and real-time lineage validation.</p>
          <div class="flex gap-2">
            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-[10px] font-bold rounded uppercase">OpenAI</span>
            <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-[10px] font-bold rounded uppercase">SQLGlot</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-blue-600 overflow-hidden relative">
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h2 class="text-4xl md:text-5xl font-black text-white mb-8">Ready to revolutionize your data stack?</h2>
      <div class="flex justify-center">
        <a href="mailto:jagadeesh.thiruveedula@example.com" class="px-12 py-5 bg-white text-blue-600 font-bold rounded-full text-xl shadow-2xl hover:bg-slate-100 transition-all transform hover:scale-105">
          Let's Build Something Great
        </a>
      </div>
    </div>
  </section>
</Layout>
