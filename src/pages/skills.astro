---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Skills & Certifications — Jagadeesh Thiruveedula">
  <main class="min-h-screen px-4 py-20 md:px-8 lg:px-12 bg-slate-950 text-slate-100">
    <section class="mx-auto flex w-full max-w-6xl flex-col gap-10">
      <header class="rounded-3xl border border-slate-800/70 bg-slate-900/40 p-8 shadow-[0_12px_40px_rgba(2,6,23,0.45)] md:p-10">
        <p class="section-eyebrow text-amber-300">[MODULE: SKILLS]</p>
        <h1 class="text-3xl font-black text-white md:text-4xl">Skills & Certifications</h1>
        <p class="mt-3 max-w-3xl text-sm text-slate-300 leading-relaxed">A concise view of the cloud, data, AI, and platform engineering stack I use to deliver robust enterprise systems.</p>
      </header>
    <!-- Skill Categories -->
    <section class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      <!-- Cloud & Data -->
      <div class="card flex flex-col p-7 gap-3 group hover:scale-[1.02] transition-all">
        <h2 class="text-lg font-bold text-blue-700 mb-1 flex gap-2 items-center">
          <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M12 20l9-7-9-7-9 7 9 7z"/><path stroke-width="2" d="M12 4v16" /></svg>
          Cloud & Data
        </h2>
        <div class="flex flex-wrap gap-2 text-xs animate-fadeIn">
          <span class="bg-blue-200 text-blue-800 px-3 py-1 rounded-full shadow-sm font-semibold">GCP</span>
          <span class="bg-blue-50 text-blue-900 px-3 py-1 rounded-full">BigQuery</span>
          <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full">Dataflow</span>
          <span class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full">Dataproc</span>
          <span class="bg-purple-50 text-purple-800 px-3 py-1 rounded-full">Composer</span>
          <span class="bg-blue-50 text-blue-900 px-3 py-1 rounded-full">Vertex AI</span>
          <span class="bg-gray-100 text-gray-800 px-3 py-1 rounded-full">AWS</span>
          <span class="bg-indigo-50 text-indigo-800 px-3 py-1 rounded-full">Azure</span>
        </div>
      </div>
      <!-- AI & ML -->
      <div class="card flex flex-col p-7 gap-3 group hover:scale-[1.02] transition-all">
        <h2 class="text-lg font-bold text-green-700 mb-1 flex gap-2 items-center">
          <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="2"/><path stroke-width="2" d="M8 12h8m-4-4v8" /></svg>
          AI & Machine Learning
        </h2>
        <div class="flex flex-wrap gap-2 text-xs animate-fadeIn">
          <span class="bg-green-200 text-green-800 px-3 py-1 rounded-full font-semibold">GenAI</span>
          <span class="bg-indigo-50 text-indigo-800 px-3 py-1 rounded-full">LLMs</span>
          <span class="bg-purple-100 text-purple-800 px-3 py-1 rounded-full">Vector DBs</span>
          <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full">RAG</span>
          <span class="bg-green-50 text-green-800 px-3 py-1 rounded-full">Vertex AI</span>
        </div>
      </div>
      <!-- DevOps -->
      <div class="card flex flex-col p-7 gap-3 group hover:scale-[1.02] transition-all">
        <h2 class="text-lg font-bold text-teal-700 mb-1 flex gap-2 items-center">
          <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          DevOps & Automation
        </h2>
        <div class="flex flex-wrap gap-2 text-xs animate-fadeIn">
          <span class="bg-teal-200 text-teal-900 px-3 py-1 rounded-full font-semibold">Terraform</span>
          <span class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full">CI/CD</span>
          <span class="bg-blue-100 text-blue-900 px-3 py-1 rounded-full">GitHub Actions</span>
          <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full">Kubernetes</span>
          <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full">Docker</span>
          <span class="bg-yellow-50 text-yellow-800 px-3 py-1 rounded-full">Cloud Monitoring</span>
        </div>
      </div>
      <!-- Databases -->
      <div class="card flex flex-col p-7 gap-3 group hover:scale-[1.02] transition-all">
        <h2 class="text-lg font-bold text-pink-700 mb-1 flex gap-2 items-center">
          <svg class="w-5 h-5 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="4"/><path stroke-width="2" d="M8 7v10M16 7v10" /></svg>
          Databases
        </h2>
        <div class="flex flex-wrap gap-2 text-xs animate-fadeIn">
          <span class="bg-pink-100 text-pink-700 px-3 py-1 rounded-full font-bold">MongoDB</span>
          <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full font-bold">Cassandra</span>
          <span class="bg-blue-100 text-blue-900 px-3 py-1 rounded-full">PostgreSQL</span>
          <span class="bg-orange-50 text-orange-900 px-3 py-1 rounded-full">MySQL</span>
          <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full">Oracle</span>
          <span class="bg-violet-50 text-violet-900 px-3 py-1 rounded-full">SQL Server</span>
        </div>
      </div>
      <!-- Programming -->
      <div class="card flex flex-col p-7 gap-3 group hover:scale-[1.02] transition-all">
        <h2 class="text-lg font-bold text-yellow-600 mb-1 flex gap-2 items-center">
          <svg class="w-5 h-5 text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M5 5v14h14V5z" /></svg>
          Programming
        </h2>
        <div class="flex flex-wrap gap-2 text-xs animate-fadeIn">
          <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full font-bold">Python</span>
          <span class="bg-blue-50 text-blue-900 px-3 py-1 rounded-full">SQL</span>
          <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full">Shell</span>
          <span class="bg-purple-100 text-purple-900 px-3 py-1 rounded-full">TypeScript</span>
          <span class="bg-sky-50 text-sky-700 px-3 py-1 rounded-full">Golang</span>
          <span class="bg-slate-100 text-slate-800 px-3 py-1 rounded-full">Node.js</span>
        </div>
      </div>
      <!-- Other -->
      <div class="card flex flex-col p-7 gap-3 group hover:scale-[1.02] transition-all">
        <h2 class="text-lg font-bold text-gray-600 mb-1 flex gap-2 items-center">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path stroke-width="2" d="M8 12h8" /></svg>
          Other
        </h2>
        <div class="flex flex-wrap gap-2 text-xs animate-fadeIn">
          <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full font-bold">Power BI</span>
          <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full font-bold">Agile & Scrum</span>
          <span class="bg-orange-50 text-orange-700 px-3 py-1 rounded-full">Blockchain</span>
          <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full">SCADA/IoT</span>
        </div>
      </div>
    </section>
    <section class="rounded-3xl border border-slate-800/70 bg-slate-900/40 p-8 shadow-[0_10px_30px_rgba(2,6,23,0.35)]">
      <h2 class="text-2xl font-bold text-white">Certifications</h2>
      <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3">
        <article class="rounded-2xl border border-slate-800/70 bg-slate-950/70 p-6 shadow-[0_10px_30px_rgba(2,6,23,0.35)]">
          <div class="font-bold text-indigo-900 dark:text-white mb-1">Google Cloud Certified - Professional Data Engineer</div>
          <div class="text-xs text-indigo-600 dark:text-indigo-300">GCP | BigQuery | Dataflow | AI/ML</div>
        </div>
        <article class="rounded-2xl border border-slate-800/70 bg-slate-950/70 p-6 shadow-[0_10px_30px_rgba(2,6,23,0.35)]">
          <div class="font-bold text-green-900 dark:text-white mb-1">Talend Data Explorer Certification</div>
          <div class="text-xs text-green-700 dark:text-green-200">Big Data | ETL | CDC</div>
        </div>
        <article class="rounded-2xl border border-slate-800/70 bg-slate-950/70 p-6 shadow-[0_10px_30px_rgba(2,6,23,0.35)]">
          <div class="font-bold text-pink-900 dark:text-white mb-1">CCA Spark and Hadoop Developer</div>
          <div class="text-xs text-pink-700 dark:text-pink-200">PySpark | Hadoop | Big Data</div>
        </div>
        <article class="rounded-2xl border border-slate-800/70 bg-slate-950/70 p-6 shadow-[0_10px_30px_rgba(2,6,23,0.35)]">
          <div class="font-bold text-yellow-900 dark:text-white mb-1">Advanced Cert in Blockchain — IIIT Hyderabad</div>
          <div class="text-xs text-yellow-700 dark:text-yellow-200">DLT | Security | Enterprise Blockchain</div>
        </div>
        <article class="rounded-2xl border border-slate-800/70 bg-slate-950/70 p-6 shadow-[0_10px_30px_rgba(2,6,23,0.35)]">
          <div class="font-bold text-blue-900 dark:text-white mb-1">Globee Award - IT World Awards®</div>
          <div class="text-xs text-blue-700 dark:text-blue-200">Leadership | Innovation | Digital Transformation</div>
        </div>
      </div>
    </section>
  </main>
</Layout>
