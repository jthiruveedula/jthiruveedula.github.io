---
interface Props {
  role: string;
  company: string;
  date: string;
  summary: string;
  chips: string;
  metric?: string;
  metricLabel?: string;
  showDot: boolean;
}

const { role, company, date, summary, chips, metric, metricLabel, showDot } = Astro.props as Props;
---

<article class="exp-card relative" style="perspective: 1000px;">
  <div class="exp-card-inner relative rounded-2xl border border-slate-800/50 bg-slate-950/80 p-6 shadow-[0_10px_30px_rgba(2,6,23,0.35)] will-change-transform">
    <!-- Left accent strip -->
    <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-gradient-to-b from-indigo-500/50 via-cyan-500/30 to-transparent" aria-hidden="true"></div>
    {showDot && <div class="absolute -left-[2.625rem] top-6 w-2 h-2 rounded-full bg-indigo-400/70 ring-4 ring-slate-950 timeline-dot" aria-hidden="true"></div>}
    <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
      <div>
        <h2 class="text-sm font-bold text-white md:text-base">{role}</h2>
        <p class="text-xs text-slate-500 mt-0.5">{company}</p>
      </div>
      <span class="font-mono text-[9px] uppercase tracking-[0.3em] text-slate-600 whitespace-nowrap">{date}</span>
    </div>
    <p class="mt-3 text-xs text-slate-400 leading-relaxed">{summary}</p>
    <div class="mt-3 flex flex-wrap items-center gap-1.5">
      {chips.split(' · ').map(tag => <span class="rounded border border-slate-700/50 bg-slate-900/50 px-2 py-0.5 font-mono text-[9px] uppercase tracking-[0.25em] text-slate-500">{tag}</span>)}
    </div>
    {metric && metricLabel && (
      <div class="mt-3 pt-2.5 border-t border-slate-800/30 flex items-baseline gap-1.5">
        <span class="font-mono text-xs font-bold text-emerald-400">{metric}</span>
        <span class="font-mono text-[9px] text-slate-600 uppercase tracking-wider">{metricLabel}</span>
      </div>
    )}
  </div>
</article>