---
// HeroNodeGraph.astro
// Enhanced node-graph background with system labels + breathing nodes + hover glow.
// Pure SVG + CSS. GSAP-powered hover tracking. Respects prefers-reduced-motion.
// SVG groups have IDs for GSAP cursor-parallax.
---

<div class="hero-bg" aria-hidden="true">
  <svg id="hero-node-svg" class="hero-bg-svg" viewBox="0 0 1440 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id="hb-glow" cx="50%" cy="40%" r="60%">
        <stop offset="0%" stop-color="#312e81" stop-opacity="0.45" />
        <stop offset="70%" stop-color="#0b1020" stop-opacity="0" />
      </radialGradient>
      <pattern id="hb-grid" width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#1e293b" stroke-width="0.5" />
      </pattern>
    </defs>

    <rect width="1440" height="800" fill="#020617" />
    <rect width="1440" height="800" fill="url(#hb-grid)" opacity="0.3" />
    <rect width="1440" height="800" fill="url(#hb-glow)" />

    <!-- Layer 1: Edges — moves slowest with cursor -->
    <g id="hb-layer-edges" class="hb-edges" fill="none" opacity="0.55">
      <!-- Data cluster edges -->
      <line class="edge-data" x1="180" y1="240" x2="260" y2="300" stroke="#818cf8" stroke-width="0.8" />
      <line class="edge-data" x1="260" y1="300" x2="340" y2="240" stroke="#818cf8" stroke-width="0.8" />
      <line class="edge-data" x1="180" y1="240" x2="340" y2="240" stroke="#818cf8" stroke-width="0.6" />
      <!-- RAG cluster edges -->
      <line class="edge-rag" x1="560" y1="200" x2="640" y2="260" stroke="#22d3ee" stroke-width="0.8" />
      <line class="edge-rag" x1="640" y1="260" x2="720" y2="200" stroke="#22d3ee" stroke-width="0.8" />
      <line class="edge-rag" x1="560" y1="200" x2="720" y2="200" stroke="#22d3ee" stroke-width="0.6" />
      <!-- Agents cluster edges -->
      <line class="edge-agents" x1="600" y1="520" x2="700" y2="460" stroke="#a78bfa" stroke-width="0.8" />
      <line class="edge-agents" x1="700" y1="460" x2="820" y2="520" stroke="#a78bfa" stroke-width="0.8" />
      <line class="edge-agents" x1="600" y1="520" x2="820" y2="520" stroke="#a78bfa" stroke-width="0.6" />
      <!-- Guardrails cluster edges -->
      <line class="edge-guard" x1="980" y1="480" x2="1060" y2="540" stroke="#34d399" stroke-width="0.8" />
      <line class="edge-guard" x1="1060" y1="540" x2="1140" y2="480" stroke="#34d399" stroke-width="0.8" />
      <line class="edge-guard" x1="980" y1="480" x2="1140" y2="480" stroke="#34d399" stroke-width="0.6" />
      <!-- Cross-cluster connections -->
      <line x1="340" y1="240" x2="560" y2="200" stroke="#334155" stroke-width="0.7" />
      <line x1="720" y1="200" x2="700" y2="460" stroke="#334155" stroke-width="0.7" />
      <line x1="820" y1="520" x2="980" y2="480" stroke="#334155" stroke-width="0.7" />
      <line x1="260" y1="300" x2="600" y2="520" stroke="#334155" stroke-width="0.5" opacity="0.4" />
      <line x1="340" y1="240" x2="1140" y2="480" stroke="#334155" stroke-width="0.4" opacity="0.3" />
    </g>

    <!-- Layer 2: Nodes — medium parallax speed -->
    <g id="hb-layer-nodes" class="hb-nodes">
      <!-- DATA cluster -->
      <circle cx="180" cy="240" r="4" fill="#818cf8" class="node-breathe node-data" />
      <circle cx="260" cy="300" r="3.5" fill="#a5b4fc" class="node-breathe node-data" />
      <circle cx="340" cy="240" r="3" fill="#6366f1" class="node-data" />
      <circle cx="220" cy="270" r="2" fill="#818cf8" opacity="0.5" class="node-data" />
      <circle cx="300" cy="270" r="2" fill="#a5b4fc" opacity="0.5" class="node-data" />

      <!-- RAG cluster -->
      <circle cx="560" cy="200" r="4" fill="#22d3ee" class="node-breathe node-rag" />
      <circle cx="640" cy="260" r="3.5" fill="#67e8f9" class="node-breathe node-rag" />
      <circle cx="720" cy="200" r="3" fill="#22d3ee" class="node-rag" />
      <circle cx="600" cy="230" r="2" fill="#22d3ee" opacity="0.5" class="node-rag" />
      <circle cx="680" cy="230" r="2" fill="#67e8f9" opacity="0.5" class="node-rag" />

      <!-- Agents cluster -->
      <circle cx="600" cy="520" r="4" fill="#a78bfa" class="node-breathe node-agents" />
      <circle cx="700" cy="460" r="3.5" fill="#c4b5fd" class="node-breathe node-agents" />
      <circle cx="820" cy="520" r="3" fill="#a78bfa" class="node-agents" />
      <circle cx="650" cy="490" r="2" fill="#a78bfa" opacity="0.5" class="node-agents" />
      <circle cx="760" cy="490" r="2" fill="#c4b5fd" opacity="0.5" class="node-agents" />

      <!-- Guardrails cluster -->
      <circle cx="980" cy="480" r="4" fill="#34d399" class="node-breathe node-guard" />
      <circle cx="1060" cy="540" r="3.5" fill="#6ee7b7" class="node-breathe node-guard" />
      <circle cx="1140" cy="480" r="3" fill="#34d399" class="node-guard" />
      <circle cx="1020" cy="510" r="2" fill="#34d399" opacity="0.5" class="node-guard" />
      <circle cx="1100" cy="510" r="2" fill="#6ee7b7" opacity="0.5" class="node-guard" />

      <!-- Ambient filler nodes -->
      <circle cx="100" cy="100" r="2" fill="#6366f1" opacity="0.35" />
      <circle cx="1340" cy="160" r="2" fill="#6366f1" opacity="0.35" />
      <circle cx="1380" cy="640" r="2" fill="#6366f1" opacity="0.35" />
      <circle cx="120" cy="680" r="2" fill="#6366f1" opacity="0.35" />
    </g>

    <!-- System labels — small mono labels on key clusters -->
    <g class="hb-labels" font-family="JetBrains Mono,monospace" font-size="8" fill="rgba(148,163,184,0.45)" letter-spacing="0.12em">
      <text class="label-data" x="270" y="330">DATA</text>
      <text class="label-rag" x="640" y="290">RAG</text>
      <text class="label-agents" x="710" y="450">AGENTS</text>
      <text class="label-guard" x="1040" y="570">GUARDRAILS</text>
    </g>

    <!-- Invisible hover targets for each cluster -->
    <g class="hb-hover-targets" fill="transparent" pointer-events="all" style="cursor: default;">
      <circle class="hit-data" cx="260" cy="260" r="80" />
      <circle class="hit-rag" cx="640" cy="230" r="80" />
      <circle class="hit-agents" cx="710" cy="490" r="80" />
      <circle class="hit-guard" cx="1060" cy="510" r="80" />
    </g>

    <!-- Layer 3: Pulse rings — fastest parallax -->
    <g id="hb-layer-pulse" class="hb-pulse">
      <circle cx="260" cy="300" r="7" fill="none" stroke="#818cf8" stroke-width="1.2" />
      <circle cx="640" cy="260" r="7" fill="none" stroke="#22d3ee" stroke-width="1.2" />
      <circle cx="700" cy="460" r="7" fill="none" stroke="#a78bfa" stroke-width="1.2" />
      <circle cx="1060" cy="540" r="7" fill="none" stroke="#34d399" stroke-width="1.2" />
      <circle cx="340" cy="240" r="5" fill="none" stroke="#6366f1" stroke-width="1" />
      <circle cx="720" cy="200" r="5" fill="none" stroke="#22d3ee" stroke-width="1" />
    </g>
  </svg>
</div>

<style>
  .hero-bg { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  .hero-bg-svg { width: 100%; height: 100%; display: block; }

  /* Edge drift animation */
  .hb-edges line {
    stroke-dasharray: 4 8;
    animation: hb-drift 22s linear infinite;
  }
  .hb-edges line:nth-child(odd) { animation-duration: 26s; animation-direction: reverse; }
  .hb-edges line:nth-child(3n) { animation-duration: 30s; }

  /* Node breathing — gentle opacity pulse on key nodes */
  .node-breathe {
    animation: hb-breathe 5s ease-in-out infinite;
  }
  .node-breathe:nth-child(2) { animation-delay: 0.5s; }
  .node-breathe:nth-child(3) { animation-delay: 1.8s; }
  .node-breathe:nth-child(4) { animation-delay: 3s; }
  .node-breathe:nth-child(5) { animation-delay: 1.2s; }
  .node-breathe:nth-child(6) { animation-delay: 2.5s; }

  @keyframes hb-breathe {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  /* Pulse rings */
  .hb-pulse circle {
    transform-box: fill-box;
    transform-origin: center;
    animation: hb-pulse 4s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    opacity: 0.6;
  }
  .hb-pulse circle:nth-child(1) { animation-delay: 0s; }
  .hb-pulse circle:nth-child(2) { animation-delay: 0.65s; }
  .hb-pulse circle:nth-child(3) { animation-delay: 1.3s; }
  .hb-pulse circle:nth-child(4) { animation-delay: 1.95s; }
  .hb-pulse circle:nth-child(5) { animation-delay: 2.6s; }
  .hb-pulse circle:nth-child(6) { animation-delay: 3.25s; }

  @keyframes hb-pulse {
    0%   { transform: scale(0.5); opacity: 0.8; }
    80%  { transform: scale(3.0); opacity: 0; }
    100% { transform: scale(3.0); opacity: 0; }
  }
  @keyframes hb-drift {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -240; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hb-edges line,
    .hb-pulse circle,
    .node-breathe { animation: none; }
  }
</style>

<script>
  const svg = document.getElementById('hero-node-svg');
  if (svg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const clusters = [
      { hit: svg.querySelector('.hit-data'), nodes: svg.querySelectorAll('.node-data'), edges: svg.querySelectorAll('.edge-data'), label: svg.querySelector('.label-data') },
      { hit: svg.querySelector('.hit-rag'), nodes: svg.querySelectorAll('.node-rag'), edges: svg.querySelectorAll('.edge-rag'), label: svg.querySelector('.label-rag') },
      { hit: svg.querySelector('.hit-agents'), nodes: svg.querySelectorAll('.node-agents'), edges: svg.querySelectorAll('.edge-agents'), label: svg.querySelector('.label-agents') },
      { hit: svg.querySelector('.hit-guard'), nodes: svg.querySelectorAll('.node-guard'), edges: svg.querySelectorAll('.edge-guard'), label: svg.querySelector('.label-guard') },
    ];

    svg.addEventListener('mousemove', (e) => {
      const rect = svg.getBoundingClientRect();
      const svgX = (e.clientX - rect.left) * (1440 / rect.width);
      const svgY = (e.clientY - rect.top) * (800 / rect.height);

      clusters.forEach(({ hit, nodes, edges, label }) => {
        if (!hit) return;
        const cx = parseFloat(hit.getAttribute('cx'));
        const cy = parseFloat(hit.getAttribute('cy'));
        const r = parseFloat(hit.getAttribute('r'));
        const dx = svgX - cx;
        const dy = svgY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const isNear = dist < r;

        nodes.forEach(n => {
          n.setAttribute('opacity', isNear ? '1' : '');
          n.setAttribute('fill', isNear ? '#f8fafc' : '');
        });
        edges.forEach(e => {
          e.setAttribute('opacity', isNear ? '0.9' : '');
          e.setAttribute('stroke', isNear ? '#f8fafc' : '');
        });
        if (label) {
          label.setAttribute('fill', isNear ? 'rgba(248,250,252,0.8)' : '');
          label.setAttribute('font-size', isNear ? '9' : '');
        }
      });
    });

    svg.addEventListener('mouseleave', () => {
      clusters.forEach(({ nodes, edges, label }) => {
        nodes.forEach(n => { n.removeAttribute('opacity'); n.removeAttribute('fill'); });
        edges.forEach(e => { e.removeAttribute('opacity'); e.removeAttribute('stroke'); });
        if (label) { label.removeAttribute('fill'); label.removeAttribute('font-size'); }
      });
    });
  }
</script>
