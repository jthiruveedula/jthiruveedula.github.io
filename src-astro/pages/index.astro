---
import Layout from '../layouts/Layout.astro';
import HeroNodeGraph from '../components/HeroNodeGraph.astro';

// Six real production projects
const projects = [
  {
    slug: 'dual-agent-platform',
    title: 'Dual-Agent Platform',
    kicker: 'Agentic Orchestration',
    summary: 'Planner + executor agents with shared memory, tool routing, and guardrails for enterprise SOP automation.',
    stack: ['Vertex AI', 'Gemini', 'Cloud Run', 'Firestore'],
    metric: '63%',
    metricLabel: 'fewer tokens vs single-agent baseline',
  },
  {
    slug: 'rag-pipeline-gcp-vertexai',
    title: 'RAG Pipeline — GCP / Vertex AI',
    kicker: 'Enterprise RAG',
    summary: 'Ingestion, chunking, hybrid retrieval, and evaluation harness on private Vertex embeddings governed by IAM and VPC-SC.',
    stack: ['Vertex AI', 'BigQuery', 'Cloud Storage', 'Matching Engine'],
    metric: '<380ms',
    metricLabel: 'p95 retrieval over 12M chunks',
  },
  {
    slug: 'policy-sop-assistant',
    title: 'Policy & SOP Assistant',
    kicker: 'Private LLM App',
    summary: 'Citation-first assistant grounded on policy corpora with refusal logic and reviewer-in-the-loop feedback.',
    stack: ['Gemma', 'LangGraph', 'Cloud Run', 'Postgres'],
    metric: '92%',
    metricLabel: 'citation precision on golden set',
  },
  {
    slug: 'gdrive-rag-assistant',
    title: 'Drive-Grounded RAG Assistant',
    kicker: 'Knowledge Surfaces',
    summary: 'Incremental Drive sync with ACL-aware retrieval and per-user grounding that respects permission boundaries.',
    stack: ['Drive API', 'Vertex AI', 'Cloud Functions'],
    metric: '0',
    metricLabel: 'ACL violations across 4 audits',
  },
  {
    slug: 'intraday-ops-intelligence',
    title: 'Intraday Ops Intelligence',
    kicker: 'Streaming + LLM',
    summary: 'Streaming features into a reasoning layer that narrates anomalies with grounded evidence and recommended actions.',
    stack: ['Pub/Sub', 'Dataflow', 'BigQuery', 'Gemini'],
    metric: '95s',
    metricLabel: 'MTTD down from 14 minutes',
  },
  {
    slug: 'openclaw-gemma-pro',
    title: 'OpenClaw / Gemma Pro',
    kicker: 'Open-Source GenAI',
    summary: 'Self-hosted Gemma stack with fine-tuned adapters, evaluation harness, and a thin API for internal teams.',
    stack: ['Gemma', 'vLLM', 'GKE', 'PEFT'],
    metric: '4.2×',
    metricLabel: 'throughput vs vanilla HF serve',
  },
];

// Pipeline stages
const pipelineStages = [
  { num: '01', name: 'Ingest',    desc: 'Structured + unstructured data acquisition with schema validation.', tech: ['BigQuery', 'GCS', 'Composer'],              color: '#818cf8' },
  { num: '02', name: 'Embed',     desc: 'Semantic encoding via domain-tuned foundation models on Vertex AI.', tech: ['Vertex AI', 'Gemini'],                      color: '#6366f1' },
  { num: '03', name: 'Retrieve',  desc: 'Hybrid dense + sparse retrieval with cross-encoder re-ranking.',     tech: ['Matching Engine', 'pgvector'],              color: '#22d3ee' },
  { num: '04', name: 'Govern',    desc: 'Lineage tracking, evaluation harness, and rollback capability.',     tech: ['IAM', 'VPC-SC', 'Dataplex'],               color: '#34d399' },
  { num: '05', name: 'Serve',     desc: 'Low-latency inference with policy-aware grounding and guardrails.',  tech: ['Cloud Run', 'CDN'],                         color: '#34d399' },
];

// Helper to map metric values to bar widths
function getBarWidth(metric: string): number {
  const cleaned = metric.replace(/[<>\s]/g, '');
  const num = parseFloat(cleaned);
  if (isNaN(num)) return 50;
  if (metric.includes('%')) return Math.min(num, 100);
  if (metric.includes('×')) return Math.min(num * 20, 92);
  if (metric.includes('ms') || metric.includes('s')) return metric.includes('<') ? 80 : 70;
  if (num === 0) return 2;
  return 50;
}

// Capability cards
const capabilityCards = [
  {
    num: '01',
    title: 'Private LLM Systems',
    desc: 'Secure, domain-specific assistants with guardrails, observability, and deployment patterns designed for real enterprise use.',
    tags: 'Production · Private · Governed',
    detail: 'Guardrails · IAM-scoped · Eval harness · Rollback-capable',
  },
  {
    num: '02',
    title: 'Enterprise RAG',
    desc: 'Context-aware retrieval pipelines that connect structured and unstructured data with governed, production-grade accuracy.',
    tags: 'Hybrid retrieval · Policy-grounded',
    detail: 'Dense + sparse search · Re-ranking · Citation-first · VPC-SC',
  },
  {
    num: '03',
    title: 'Agentic Workflows',
    desc: 'Orchestration patterns for multi-step reasoning, task routing, and reliable execution on cloud-native infrastructure.',
    tags: 'Multi-step · Observable · Resilient',
    detail: 'Tool routing · Planner–executor · Memory patterns · Guardrails',
  },
];
---

<Layout
  title="Jagadeesh Thiruveedula — GenAI Systems Architect | Private LLM & RAG"
  description="A premium portfolio for a GenAI Systems Architect building private LLM systems, enterprise RAG, and governed AI workflows on GCP."
>

  <!-- ═══════════════════════════════════════════════════════════════
       §1 · SIGNAL — Hero
  ═══════════════════════════════════════════════════════════════ -->
  <section class="hero-section relative isolate flex items-center overflow-hidden bg-slate-950" style="min-height: 100svh;">
    <!-- Node graph background (owns the bg — no competing orbs) -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <HeroNodeGraph />
      <!-- Single edge vignette — frames content without competing -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_40%,rgba(2,6,23,0.7)_100%)]"></div>
    </div>

      <div class="container relative z-10 mx-auto px-4 md:px-6 py-24">
      <div class="mx-auto flex max-w-3xl flex-col items-start gap-4">

        <!-- H1 — two-line with line stagger -->
        <h1 id="hero-headline" class="hero-title font-bold tracking-tight text-white" style="font-size: clamp(1.5rem, 1rem + 2vw, 2.75rem); line-height: 1.2;">
          <span class="hero-line">Command Surface</span>
          <span class="hero-line">for Production AI</span>
        </h1>

        <!-- Description -->
        <p class="hero-description max-w-lg text-sm text-slate-300 font-light leading-relaxed md:text-base">
          Private LLM applications, enterprise-grade RAG pipelines, and governed agentic workflows on GCP — built for teams that need performance, security, and operational clarity.
        </p>

        <!-- Tag pills -->
        <div class="hero-tags flex flex-wrap items-center gap-2 mt-1">
          {['GCP-native', 'Vertex AI', 'Token-efficient', 'Governed workflows'].map((item) => (
            <span class="sys-chip">{item}</span>
          ))}
        </div>

        <!-- CTAs -->
        <div class="hero-ctas flex flex-wrap items-center gap-4 mt-3">
          <a href="#deployments" class="btn-primary inline-flex items-center gap-2 rounded-full bg-cyan-400 px-6 py-2.5 text-sm font-semibold text-slate-950 shadow-[0_0_18px_rgba(34,211,238,0.18)] hover:bg-cyan-300 hover:scale-[1.02] transition-all duration-200">
            See the systems
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="btn-primary inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-6 py-2.5 text-sm font-medium text-slate-300 hover:border-cyan-400/40 hover:text-cyan-100 backdrop-blur-sm transition-all duration-200">
            Discuss a system
          </a>
        </div>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0">
      <span class="font-mono text-[10px] tracking-[0.3em] text-slate-600 uppercase rotate-0">scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-slate-600 to-transparent scroll-line"></div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       §2 · TENSION — The Governance Problem (sticky scroll)
  ═══════════════════════════════════════════════════════════════ -->
  <section class="complexity-section relative bg-slate-950" style="height: 200vh;">
    <div class="sticky top-0 h-screen flex items-center justify-center overflow-hidden border-t border-slate-800/40">

      <!-- Section dissolve transition zone from hero -->
      <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-slate-950 to-transparent z-20 pointer-events-none"></div>

      <!-- Full-bleed SVG background -->
      <div class="absolute inset-0 flex items-center justify-center tension-viz" aria-hidden="true">
        <svg class="tension-svg w-full h-full max-w-[95vw] max-h-[90vh]" viewBox="0 0 800 500" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="node-glow">
              <feGaussianBlur stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="pulse-glow">
              <feGaussianBlur stdDeviation="4" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <marker id="arrow-clean" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
              <path d="M0,0.5 L0,5.5 L5,3 z" fill="#34d399"/>
            </marker>
            <marker id="arrow-chaos" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
              <path d="M0,0.5 L0,5.5 L5,3 z" fill="#f59e0b"/>
            </marker>
            <linearGradient id="energy-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#34d399" stop-opacity="0"/>
              <stop offset="50%" stop-color="#34d399" stop-opacity="0.8"/>
              <stop offset="100%" stop-color="#34d399" stop-opacity="0"/>
            </linearGradient>
          </defs>

          <!-- Grid background -->
          <g class="tension-grid" opacity="0.06">
            <line x1="0" y1="50" x2="800" y2="50" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="100" x2="800" y2="100" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="150" x2="800" y2="150" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="200" x2="800" y2="200" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="250" x2="800" y2="250" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="300" x2="800" y2="300" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="350" x2="800" y2="350" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="400" x2="800" y2="400" stroke="#475569" stroke-width="0.4"/>
            <line x1="0" y1="450" x2="800" y2="450" stroke="#475569" stroke-width="0.4"/>
            <line x1="60" y1="0" x2="60" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="120" y1="0" x2="120" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="180" y1="0" x2="180" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="240" y1="0" x2="240" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="300" y1="0" x2="300" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="360" y1="0" x2="360" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="420" y1="0" x2="420" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="480" y1="0" x2="480" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="540" y1="0" x2="540" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="600" y1="0" x2="600" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="660" y1="0" x2="660" y2="500" stroke="#475569" stroke-width="0.4"/>
            <line x1="720" y1="0" x2="720" y2="500" stroke="#475569" stroke-width="0.4"/>
          </g>

          <!-- Grid row highlights (light up during governance phase) -->
          <g class="grid-highlights" opacity="0">
            <rect class="grid-hl" x="300" y="148" width="200" height="4" rx="2" fill="#6366f1" opacity="0"/>
            <rect class="grid-hl" x="300" y="198" width="200" height="4" rx="2" fill="#6366f1" opacity="0"/>
            <rect class="grid-hl" x="300" y="248" width="200" height="4" rx="2" fill="#6366f1" opacity="0"/>
          </g>

          <!-- Source nodes (left) with pulse rings -->
          <g class="tension-sources">
            <circle class="source-pulse-ring" cx="60" cy="90"  r="28" fill="none" stroke="#f59e0b" stroke-width="0.8" opacity="0"/>
            <circle class="source-node" cx="60" cy="90"  r="22" fill="#0f172a" stroke="#f59e0b" stroke-width="1.8"/>
            <text x="60" y="95" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="10" fill="#fbbf24" font-weight="bold">API</text>
            <circle class="source-pulse-ring" cx="60" cy="250" r="28" fill="none" stroke="#f59e0b" stroke-width="0.8" opacity="0"/>
            <circle class="source-node" cx="60" cy="250" r="22" fill="#0f172a" stroke="#f59e0b" stroke-width="1.8"/>
            <text x="60" y="255" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="10" fill="#fbbf24" font-weight="bold">DB</text>
            <circle class="source-pulse-ring" cx="60" cy="410" r="28" fill="none" stroke="#f59e0b" stroke-width="0.8" opacity="0"/>
            <circle class="source-node" cx="60" cy="410" r="22" fill="#0f172a" stroke="#f59e0b" stroke-width="1.8"/>
            <text x="60" y="415" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="10" fill="#fbbf24" font-weight="bold">DOCS</text>
          </g>

          <!-- Data packet dots (chaos phase — scattered) -->
          <g class="chaos-dots" opacity="0">
            <circle class="chaos-dot" cx="230" cy="160" r="4" fill="#f59e0b" opacity="0.9"/>
            <circle class="chaos-dot" cx="370" cy="100" r="3" fill="#f59e0b" opacity="0.6"/>
            <circle class="chaos-dot" cx="500" cy="380" r="4" fill="#f59e0b" opacity="0.7"/>
            <circle class="chaos-dot" cx="310" cy="420" r="3" fill="#f59e0b" opacity="0.5"/>
            <circle class="chaos-dot" cx="550" cy="150" r="3.5" fill="#f59e0b" opacity="0.6"/>
            <circle class="chaos-dot" cx="180" cy="320" r="3" fill="#f59e0b" opacity="0.7"/>
            <circle class="chaos-dot" cx="440" cy="280" r="4" fill="#f59e0b" opacity="0.5"/>
            <circle class="chaos-dot" cx="280" cy="60" r="3" fill="#f59e0b" opacity="0.8"/>
          </g>

          <!-- Target node (right) with pulse ring -->
          <g class="tension-target">
            <circle class="target-pulse-ring" cx="740" cy="250" r="40" fill="none" stroke="#34d399" stroke-width="0.6" opacity="0" filter="url(#pulse-glow)"/>
            <circle cx="740" cy="250" r="30" fill="#0f172a" stroke="#34d399" stroke-width="1.8" filter="url(#node-glow)"/>
            <text x="740" y="244" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="10" fill="#34d399" font-weight="bold">AI</text>
            <text x="740" y="260" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="10" fill="#34d399" font-weight="bold">SYS</text>
          </g>

          <!-- CHAOS PATHS (amber, phase 1) -->
          <g class="chaos-paths">
            <path class="chaos-p" d="M82,90  C220,400 380,20  520,380 S660,140 710,250" fill="none" stroke="#f59e0b" stroke-width="1.8" stroke-dasharray="1000" stroke-dashoffset="1000" opacity="0.7" stroke-linecap="round" marker-end="url(#arrow-chaos)"/>
            <path class="chaos-p" d="M82,250 C180,440 400,30  580,460 S680,180 710,250" fill="none" stroke="#f59e0b" stroke-width="1.8" stroke-dasharray="1000" stroke-dashoffset="1000" opacity="0.6" stroke-linecap="round" marker-end="url(#arrow-chaos)"/>
            <path class="chaos-p" d="M82,410 C140,30  460,490 580,60  S700,320 710,250" fill="none" stroke="#f59e0b" stroke-width="1.8" stroke-dasharray="1000" stroke-dashoffset="1000" opacity="0.65" stroke-linecap="round" marker-end="url(#arrow-chaos)"/>
          </g>

          <!-- GOVERNANCE LAYER (phase 2) -->
          <g class="gov-layer" opacity="0">
            <rect class="gov-glow" x="280" y="148" width="180" height="204" rx="16" fill="#6366f1" opacity="0"/>
            <rect x="295" y="163" width="150" height="174" rx="10" fill="#0f172a" stroke="#6366f1" stroke-width="1.8"/>
            <text x="370" y="220" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#818cf8" letter-spacing="3" font-weight="bold">POLICY</text>
            <text x="370" y="240" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="#6366f1" letter-spacing="3" font-weight="bold">LAYER</text>
            <line x1="315" y1="256" x2="425" y2="256" stroke="#6366f1" stroke-width="0.6" opacity="0.5"/>
            <text x="370" y="276" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="9" fill="#475569">eval · guard · rollback</text>
            <!-- Governance particles -->
            <circle class="gov-particle" cx="290" cy="170" r="2" fill="#818cf8" opacity="0"/>
            <circle class="gov-particle" cx="450" cy="200" r="1.5" fill="#818cf8" opacity="0"/>
            <circle class="gov-particle" cx="310" cy="330" r="2" fill="#818cf8" opacity="0"/>
            <circle class="gov-particle" cx="440" cy="310" r="1.5" fill="#818cf8" opacity="0"/>
            <circle class="gov-particle" cx="370" cy="150" r="2" fill="#818cf8" opacity="0"/>
            <!-- Scanning line -->
            <rect class="gov-scan-line" x="295" y="163" width="150" height="2" fill="#818cf8" opacity="0" filter="url(#pulse-glow)"/>
          </g>

          <!-- CLEAN PATHS (phase 3, emerald) -->
          <g class="clean-paths" opacity="0">
            <path class="clean-p" d="M82,90  Q190,90  295,230 L445,230 Q570,230 710,250" fill="none" stroke="#34d399" stroke-width="2.2" stroke-dasharray="700" stroke-dashoffset="700" stroke-linecap="round" marker-end="url(#arrow-clean)"/>
            <path class="clean-p" d="M82,250 L295,250 L445,250 L710,250" fill="none" stroke="#34d399" stroke-width="2.2" stroke-dasharray="700" stroke-dashoffset="700" stroke-linecap="round" marker-end="url(#arrow-clean)"/>
            <path class="clean-p" d="M82,410 Q190,410 295,270 L445,270 Q570,270 710,250" fill="none" stroke="#34d399" stroke-width="2.2" stroke-dasharray="700" stroke-dashoffset="700" stroke-linecap="round" marker-end="url(#arrow-clean)"/>
            <circle class="clean-data-dot" cx="190" cy="120" r="4" fill="#34d399" opacity="0"/>
            <circle class="clean-data-dot" cx="370" cy="245" r="4" fill="#34d399" opacity="0"/>
            <circle class="clean-data-dot" cx="570" cy="250" r="4" fill="#34d399" opacity="0"/>
          </g>
        </svg>
      </div>

      <!-- Compact copy overlay card -->
      <div class="relative z-10 w-full container mx-auto px-4 md:px-6">
        <div class="max-w-sm ml-0 md:ml-6 p-4 md:p-5 rounded-2xl border border-slate-800/40 bg-slate-950/70 backdrop-blur-md shadow-xl">
          <p class="section-eyebrow text-amber-400/80">TENSION</p>
          <h2 class="text-lg md:text-xl font-bold text-white leading-snug complexity-text">
            The gap between a demo and production is <em class="not-italic text-slate-400">governance.</em>
          </h2>
          <p class="mt-2 text-xs md:text-sm text-slate-400 leading-relaxed complexity-subtext">
            Enterprise data is messy. APIs are unpredictable. Without orchestration, AI is just a parlor trick.
          </p>
          <!-- Phase indicator -->
          <div class="mt-4 flex items-center gap-2 phase-indicator opacity-0">
            <div class="h-px w-6 bg-emerald-500"></div>
            <span class="font-mono text-[11px] text-emerald-400 tracking-widest uppercase">Governance applied</span>
          </div>
          <!-- Demo vs Production diagram -->
          <div class="tension-diagram mt-4 flex flex-col gap-2 opacity-0 translate-y-4">
            <span class="font-mono text-[9px] uppercase tracking-[0.2em] text-slate-600">Architecture Gap</span>
            <div class="flex items-center gap-2">
              <div class="demo-box flex-1 rounded-lg border border-amber-500/20 bg-amber-500/5 p-1.5 md:p-2 text-center">
                <span class="font-mono text-[9px] uppercase tracking-widest text-amber-400/60">DEMO</span>
                <div class="mt-1 mx-auto w-10 h-6 rounded border border-amber-500/30 bg-amber-500/10 flex items-center justify-center">
                  <span class="font-mono text-[7px] text-amber-300/80">LLM</span>
                </div>
              </div>
              <div class="demo-prod-arrow shrink-0 flex items-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5" class="opacity-40">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
              <div class="prod-box flex-[1.5] rounded-lg border border-emerald-500/20 bg-emerald-500/5 p-1.5 md:p-2">
                <span class="font-mono text-[9px] uppercase tracking-widest text-emerald-400/60 text-center block">PRODUCTION</span>
                <div class="mt-1 flex items-center justify-center gap-0.5">
                  <div class="w-7 h-5 rounded border border-emerald-500/30 bg-emerald-500/10 flex items-center justify-center">
                    <span class="font-mono text-[6px] text-emerald-300/80">LLM</span>
                  </div>
                  <div class="w-7 h-5 rounded border border-cyan-500/30 bg-cyan-500/10 flex items-center justify-center">
                    <span class="font-mono text-[6px] text-cyan-300/80">DATA</span>
                  </div>
                  <div class="w-7 h-5 rounded border border-indigo-500/30 bg-indigo-500/10 flex items-center justify-center">
                    <span class="font-mono text-[6px] text-indigo-300/80">POL</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       §3 · PIPELINE — Architectural Clarity
  ═══════════════════════════════════════════════════════════════ -->
  <section class="orchestration-section bg-slate-900 py-24 border-t border-slate-800/40 relative overflow-hidden">
    <!-- Animated blueprint background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="pipe-grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(52,211,153,0.06)" stroke-width="0.5" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#pipe-grid)" />
      </svg>
    </div>

    <div class="container relative z-10 mx-auto px-4 md:px-6">
      <div class="mb-16 max-w-3xl">
        <p class="section-eyebrow text-emerald-400">PIPELINE</p>
        <h2 class="text-2xl font-bold text-white md:text-3xl">Architectural clarity.</h2>
