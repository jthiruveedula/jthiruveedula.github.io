</style>


<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ─────────────────────────────────────────────────────────────────
  // SECTION-AWARE NAV LABEL
  // ─────────────────────────────────────────────────────────────────
  const navLabel = document.getElementById('nav-section-label');
  const names = ['Jagadeesh', 'Thiruveedula', 'J. T.', 'Jagadeesh T.', 'Jagadeesh Thiruveedula'];
  const sectionDefs = [
    { trigger: '.complexity-section',   label: names[0] },
    { trigger: '.orchestration-section',label: names[1] },
    { trigger: '.capabilities-section', label: names[2] },
    { trigger: '.deployments-section',  label: names[3] },
    { trigger: '.contact-section',      label: names[4] },
  ];

  if (navLabel) {
    sectionDefs.forEach(({ trigger, label }) => {
      ScrollTrigger.create({
        trigger,
        start: 'top 55%',
        end: 'bottom 45%',
        onEnter:     () => { navLabel.textContent = label; navLabel.style.opacity = '1'; },
        onLeave:     () => { navLabel.textContent = '';    navLabel.style.opacity = '0'; },
        onEnterBack: () => { navLabel.textContent = label; navLabel.style.opacity = '1'; },
        onLeaveBack: () => { navLabel.textContent = '';    navLabel.style.opacity = '0'; },
        invalidateOnRefresh: true,
      });
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // §1 · HERO SEQUENCE
  // ─────────────────────────────────────────────────────────────────
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {

    gsap.from('.hero-line', { opacity: 0, y: 30, rotateX: -45, duration: 0.8, stagger: 0.08, ease: 'power4.out' });
    gsap.from('.hero-description', { opacity: 0, y: 15, duration: 0.8, delay: 0.5, ease: 'power3.out' });
    const tlHero = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Set initial states
    gsap.set(['.hero-description', '.hero-ctas'], { y: 12, opacity: 0 });
    gsap.set('.hero-tags',        { y: 8, opacity: 0 });
    gsap.set('.scroll-indicator', { opacity: 0 });

    tlHero
      .to('.hero-description', { y: 0, opacity: 1, duration: 0.6 })
      .to('.hero-tags',        { y: 0, opacity: 1, duration: 0.4 }, '-=0.4')
      .to('.hero-ctas',        { y: 0, opacity: 1, duration: 0.4 }, '-=0.3')
      .to('.scroll-indicator', { opacity: 1, duration: 0.4 }, '-=0.15');

    // ── Cursor parallax on HeroNodeGraph SVG layers ──
    const heroSection  = document.querySelector('.hero-section') as HTMLElement;
    const layerEdges   = document.getElementById('hb-layer-edges');
    const layerNodes   = document.getElementById('hb-layer-nodes');
    const layerPulse   = document.getElementById('hb-layer-pulse');

    if (heroSection && layerEdges && layerNodes && layerPulse) {
      const qxE = gsap.quickTo(layerEdges, 'x', { duration: 1.0, ease: 'power3.out' });
      const qyE = gsap.quickTo(layerEdges, 'y', { duration: 1.0, ease: 'power3.out' });
      const qxN = gsap.quickTo(layerNodes, 'x', { duration: 0.7, ease: 'power3.out' });
      const qyN = gsap.quickTo(layerNodes, 'y', { duration: 0.7, ease: 'power3.out' });
      const qxP = gsap.quickTo(layerPulse, 'x', { duration: 0.45, ease: 'power3.out' });
      const qyP = gsap.quickTo(layerPulse, 'y', { duration: 0.45, ease: 'power3.out' });

      heroSection.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = heroSection.getBoundingClientRect();
        const dx = (e.clientX - rect.width  / 2) / rect.width;   // -0.5 → 0.5
        const dy = (e.clientY - rect.height / 2) / rect.height;  // -0.5 → 0.5

        qxE(dx * 12);  qyE(dy * 8);
        qxN(dx * 20);  qyN(dy * 14);
        qxP(dx * 30);  qyP(dy * 20);
      }, { passive: true });

      heroSection.addEventListener('mouseleave', () => {
        gsap.to([layerEdges, layerNodes, layerPulse], { x: 0, y: 0, duration: 1.2, ease: 'power3.out' });
      });
    }

    // ── Hero scroll-out parallax (SVG dims as hero exits) ──
    gsap.to('#hero-node-svg', {
      opacity: 0,
      scale: 1.03,
      scrollTrigger: {
        trigger: '.hero-section',
        start: 'top top',
        end: 'bottom top',
        scrub: 1.5,
        invalidateOnRefresh: true,
      }
    });
  }


  // ─────────────────────────────────────────────────────────────────
  // §2 · TENSION — 3-phase cinematic (chaos → governance → resolution)
  // ─────────────────────────────────────────────────────────────────
  const tlTension = gsap.timeline({
    scrollTrigger: {
      trigger: '.complexity-section',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1.8,
      invalidateOnRefresh: true,
    }
  });

  // ── PHASE 1: CHAOS (0.00 → 0.35) ──
  // Chaos paths whip-draw with dramatic spring-back
  tlTension.to('.chaos-p', {
    strokeDashoffset: 0,
    stagger: 0.08,
    duration: 0.35,
    ease: 'back.out(3)',
  }, 0);

  // Source pulse rings expand with heartbeat stagger
  tlTension.to('.source-pulse-ring', {
    opacity: 0.6,
    scale: 1.35,
    transformOrigin: 'center',
    stagger: 0.12,
    duration: 0.3,
    ease: 'power2.out',
  }, 0.05);

  // Chaos dots scatter in with small random motion offset
  tlTension.to('.chaos-dots', {
    opacity: 1,
    duration: 0.25,
    ease: 'power1.out',
  }, 0.1);

  // Chaos dots drift during phase 1 (via onUpdate approach using a tween)
  tlTension.to('.chaos-dot', {
    x: gsap.utils.wrap([-12, 8, 6, -8, 10, -6, 4, -10]),
    y: gsap.utils.wrap([8, -10, -6, 12, -8, 6, -12, 4]),
    duration: 0.35,
    ease: 'sine.inOut',
  }, 0.15);

  // ── PHASE 2: GOVERNANCE (0.30 → 0.65) ──
  // Governance layer materializes with scale-up + blur reveal
  tlTension.fromTo('.gov-layer',
    { opacity: 0, scale: 0.85, transformOrigin: '370px 250px', filter: 'blur(4px)' },
    { opacity: 1, scale: 1, filter: 'blur(0px)', duration: 0.4, ease: 'power3.out' },
    0.30
  );

  // Governance glow pulse
  tlTension.to('.gov-glow', {
    opacity: 0.1,
    scale: 1.06,
    duration: 0.5,
    ease: 'sine.inOut',
    yoyo: true,
    repeat: 1,
  }, 0.33);

  // Scanning line sweeps top→bottom inside governance layer
  tlTension.to('.gov-scan-line', {
    opacity: 0.7,
    y: 170,
    duration: 0.6,
    ease: 'power1.inOut',
    yoyo: true,
    repeat: 1,
  }, 0.35);

  // Grid highlights light up sequentially
  tlTension.to('.grid-highlights', { opacity: 1, duration: 0.1 }, 0.36);
  tlTension.to('.grid-hl', {
    opacity: 0.15,
    stagger: 0.06,
    duration: 0.2,
    ease: 'power1.out',
  }, 0.38);

  // Governance particles float/orbit
  tlTension.to('.gov-particle', {
    opacity: 0.7,
    y: gsap.utils.wrap([-12, 10, -8, 14, -10]),
    x: gsap.utils.wrap([6, -8, 12, -6, 5]),
    duration: 0.5,
    ease: 'sine.inOut',
  }, 0.42);

  // Governance layer border glow intensifies
  tlTension.to('.gov-layer rect:last-child', {
    stroke: '#818cf8',
    strokeWidth: 2.5,
    duration: 0.3,
    ease: 'power2.out',
  }, 0.48);

  // ── PHASE 3: RESOLUTION (0.60 → 1.0) ──
  // Chaos paths dissolve
  tlTension.to('.chaos-p',      { opacity: 0, scale: 0.9, transformOrigin: 'center', duration: 0.2 }, 0.60);
  tlTension.to('.chaos-dots',   { opacity: 0, scale: 0.7, duration: 0.15 }, 0.60);
  tlTension.to('.source-pulse-ring', { opacity: 0, duration: 0.12 }, 0.60);
  tlTension.to('.grid-highlights',   { opacity: 0, duration: 0.1 }, 0.62);

  // Clean paths emerge
  tlTension.to('.clean-paths',  { opacity: 1, duration: 0.1 }, 0.64);
  tlTension.to('.clean-p', {
    strokeDashoffset: 0,
    stagger: 0.08,
    duration: 0.36,
    ease: 'power3.out',
  }, 0.66);

  // Target node expands with strong emerald pulse
  tlTension.to('.target-pulse-ring', {
    opacity: 0.5,
    scale: 1.2,
    transformOrigin: 'center',
    duration: 0.35,
    ease: 'power2.out',
  }, 0.68);

  // Clean data dots pulse in with heartbeat stagger
  tlTension.to('.clean-data-dot', {
    opacity: 1,
    scale: 1.4,
    stagger: 0.1,
    duration: 0.25,
    ease: 'back.out(2.5)',
  }, 0.72);

  // Source nodes transition amber→emerald
  tlTension.to('.source-node',  { stroke: '#34d399', duration: 0.2 }, 0.82);
  tlTension.to('.tension-sources text', { fill: '#34d399', duration: 0.15 }, 0.84);

  // Phase indicator fades in at final state
  tlTension.to('.phase-indicator', { opacity: 1, duration: 0.15 }, 0.88);

  // ── Chaos dots independent drift animation (runs concurrently) ──
  // (already done inline above via tlTension.to on .chaos-dot)

  // ── Tension diagram — DEMO vs PRODUCTION scroll-in ──
  const tlTensionDiagram = gsap.timeline({
    scrollTrigger: {
      trigger: '.tension-diagram',
      start: 'top 85%',
      end: 'top 40%',
      toggleActions: 'play none none none',
      invalidateOnRefresh: true,
    }
  });

  tlTensionDiagram
    .to('.tension-diagram', { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' })
    .fromTo('.demo-box', { opacity: 0, x: -12 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2')
    .fromTo('.prod-box', { opacity: 0, x: 12 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
    .fromTo('.demo-prod-arrow', { opacity: 0, scaleX: 0 }, { opacity: 1, scaleX: 1, duration: 0.3, ease: 'back.out(2)' }, '-=0.3')
    .to('.demo-box', { opacity: 0.5, duration: 0.3 }, '+=0.3');

  // ── Global entry patterns: section eyebrow + heading + body ──
  const sectionEntries = [
    { sec: '.orchestration-section', eyebrow: '.section-eyebrow', heading: 'h2' },
    { sec: '.capabilities-section', eyebrow: '.section-eyebrow', heading: 'h2' },
    { sec: '.deployments-section', eyebrow: '.section-eyebrow', heading: 'h2' },
    { sec: '.contact-section', eyebrow: '.section-eyebrow', heading: 'h2' },
  ];

  sectionEntries.forEach(({ sec, eyebrow, heading }) => {
    const section = document.querySelector(sec);
    if (!section) return;

    const e = section.querySelector(eyebrow) as HTMLElement;
    const h = section.querySelector(heading) as HTMLElement;
    const p = section.querySelector('p:not(.section-eyebrow)') as HTMLElement;

    if (e) gsap.from(e, { opacity: 0, y: 10, duration: 0.5, ease: 'power2.out', scrollTrigger: { trigger: section, start: 'top 82%', toggleActions: 'play none none none', invalidateOnRefresh: true } });
    if (h) gsap.from(h, { opacity: 0, y: 14, duration: 0.6, ease: 'power2.out', scrollTrigger: { trigger: section, start: 'top 80%', toggleActions: 'play none none none', invalidateOnRefresh: true } });
    if (p && !p.classList.contains('section-eyebrow')) gsap.from(p, { opacity: 0, y: 8, duration: 0.5, delay: 0.1, ease: 'power2.out', scrollTrigger: { trigger: section, start: 'top 78%', toggleActions: 'play none none none', invalidateOnRefresh: true } });
  });


  // ─────────────────────────────────────────────────────────────────
  // §3 · PIPELINE — sequential card reveal + progress line + rail
  // ─────────────────────────────────────────────────────────────────
  const tlPipeline = gsap.timeline({
    scrollTrigger: {
      trigger: '.orchestration-section',
      start: 'top 55%',
      end: 'bottom 60%',
      scrub: 0.6,
      invalidateOnRefresh: true,
    }
  });

  // Rail line fills top to bottom
  if (document.querySelector('.rail-fill-line')) {
    tlPipeline.to('.rail-fill-line', { height: '100%', duration: 2, ease: 'none' }, 0);
  }

  // Progress line draws left to right
  if (document.querySelector('.pipeline-progress-line')) {
    tlPipeline.to('.pipeline-progress-line', { width: '100%', duration: 2, ease: 'none' }, 0);
  }

  // Each step activates as line reaches it
  const steps = document.querySelectorAll('.pipeline-step');
  steps.forEach((step, i) => {
    const offset = (i / (steps.length - 1)) * 1.8;

    // Card slides in from direction based on parity
    tlPipeline.to(step, {
      opacity: 1,
      x: 0,
      duration: 0.35,
      ease: 'power2.out',
    }, offset);

    // Step number brightens
    const numEl = step.querySelector('.step-number') as HTMLElement;
    if (numEl) {
      tlPipeline.to(numEl, { opacity: 1, duration: 0.15 }, offset + 0.05);
    }

    // Status dot turns emerald
    const dot = step.querySelector('.step-status') as HTMLElement;
    if (dot) {
      tlPipeline.to(dot, {
        backgroundColor: '#34d399',
        boxShadow: '0 0 8px rgba(52,211,153,0.6)',
        duration: 0.15,
      }, offset + 0.1);
    }

    // Rail node glows when its card activates
    const railDot = document.querySelector(`.rail-dot-${i}`) as HTMLElement;
    if (railDot) {
      tlPipeline.to(railDot, {
        borderColor: 'rgba(52,211,153,0.8)',
        backgroundColor: '#34d399',
        boxShadow: '0 0 10px rgba(52,211,153,0.5)',
        duration: 0.2,
      }, offset);
    }

    // Card border accent
    const card = step.querySelector('div') as HTMLElement;
    if (card) {
      tlPipeline.to(card, {
        borderColor: 'rgba(52,211,153,0.3)',
        duration: 0.2,
      }, offset + 0.08);
    }
  });


  document.querySelectorAll('.btn-primary').forEach((btn) => {
    btn.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      gsap.to(btn, { x: x * 0.15, y: y * 0.15, duration: 0.3, ease: 'power2.out' });
    });
    btn.addEventListener('mouseleave', () => gsap.to(btn, { x: 0, y: 0, duration: 0.4, ease: 'power3.out' }));
  });

  function parseMetricValue(raw: string) {
    const match = raw.match(/^(\D*)(-?\d+(?:\.\d+)?)(.*)$/);
    if (!match) return null;
    return {
      prefix: match[1] || '',
      target: parseFloat(match[2]),
      suffix: match[3] || '',
    };
  }

  document.querySelectorAll('.metric-value').forEach((node) => {
    const el = node as HTMLElement;
    const raw = el.dataset.value || '';
    const parsed = parseMetricValue(raw);
    if (!parsed) return;

    const { prefix, target, suffix } = parsed;
    const easeOutExpo = (t: number) => 1 - Math.pow(2, -10 * t);
    const observer = new IntersectionObserver((entries) => {
      if (!entries[0]?.isIntersecting) return;
      const from = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - from) / 1800);
        const value = target * easeOutExpo(p);
        const digits = target % 1 === 0 ? 0 : 1;
        el.textContent = `${prefix}${value.toFixed(digits)}${suffix}`;
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
      observer.disconnect();
    }, { threshold: 0.5 });
    observer.observe(el);
  });

  // ─────────────────────────────────────────────────────────────────
  // §4 · CAPABILITIES — stacking cards with depth scaling
  // ─────────────────────────────────────────────────────────────────
  // §4 · CAPABILITIES — reduced depth stacking
  const cards = gsap.utils.toArray<HTMLElement>('.stack-card');
  cards.forEach((card, i) => {
    if (i === 0) return;

    gsap.fromTo(card,
      { y: 40, scale: 0.97, opacity: 0.9 },
      {
        y: 0, scale: 1, opacity: 1,
        duration: 1,
        scrollTrigger: {
          trigger: card,
          start: 'top 82%',
          end: 'top 32%',
          scrub: true,
          invalidateOnRefresh: true,
        }
      }
    );

    if (i > 0) {
      const prevCard = cards[i - 1];
      gsap.to(prevCard, {
        scale: 0.98,
        scrollTrigger: {
          trigger: card,
          start: 'top 60%',
          end: 'top 20%',
          scrub: true,
          invalidateOnRefresh: true,
        }
      });
    }
  });

  // 3D tilt on capability cards
  if (!prefersReduced) {
    document.querySelectorAll('.capability-card').forEach((card) => {
      const inner = card.querySelector('.cap-card-inner') as HTMLElement;
      if (!inner) return;
      card.addEventListener('mousemove', (ev) => {
        const rect = card.getBoundingClientRect();
        const x = ev.clientX - rect.left;
        const y = ev.clientY - rect.top;
        const halfW = rect.width / 2;
        const halfH = rect.height / 2;
        const rotateY = ((x - halfW) / halfW) * 1.5;
        const rotateX = ((halfH - y) / halfH) * 1.5;
        gsap.to(inner, { rotateX, rotateY, duration: 0.4, ease: 'power2.out', overwrite: 'auto' });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(inner, { rotateX: 0, rotateY: 0, duration: 0.5, ease: 'power3.out' });
      });
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // §5 · DEPLOYMENTS — proof cards stagger in
  // ─────────────────────────────────────────────────────────────────
  gsap.to('.proof-card', {
    opacity: 1,
    y: 0,
    duration: 0.7,
    stagger: 0.08,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '.proof-grid',
      start: 'top 75%',
      toggleActions: 'play none none none',
      invalidateOnRefresh: true,
    }
  });

  // Canvas constellation (lightweight hover-reactive dots)
  (function initConstellation() {
    const canvas = document.getElementById('constellation-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const section = canvas.parentElement!;
    let dots: { x: number; y: number; baseOpacity: number; lit: boolean }[] = [];
    let mouse = { x: -9999, y: -9999 };
    let animId: number;
    let isIdle = true;

    function resize() {
      canvas.width  = section.offsetWidth;
      canvas.height = section.offsetHeight;
      buildDots();
    }

    function buildDots() {
      dots = [];
      const cols = Math.floor(canvas.width  / 80);
      const rows = Math.floor(canvas.height / 80);
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          dots.push({
            x: (c + 0.5) * (canvas.width  / cols) + (Math.random() - 0.5) * 30,
            y: (r + 0.5) * (canvas.height / rows) + (Math.random() - 0.5) * 30,
            baseOpacity: 0.03 + Math.random() * 0.04,
            lit: false,
          });
        }
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const proximity = 140;

      dots.forEach(dot => {
        const dx   = dot.x - mouse.x;
        const dy   = dot.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const lit  = dist < proximity;
        const op   = lit
          ? dot.baseOpacity + (1 - dist / proximity) * 0.35
          : dot.baseOpacity;

        ctx.beginPath();
        ctx.arc(dot.x, dot.y, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(52,211,153,${op})`;
        ctx.fill();

        // Connect nearby lit dots
        if (lit) {
          dots.forEach(other => {
            if (other === dot) return;
            const odx  = other.x - dot.x;
            const ody  = other.y - dot.y;
            const odist = Math.sqrt(odx * odx + ody * ody);
            if (odist < 100 && odist > 0) {
              const lineOp = (1 - odist / 100) * 0.12;
              ctx.beginPath();
              ctx.moveTo(dot.x, dot.y);
              ctx.lineTo(other.x, other.y);
              ctx.strokeStyle = `rgba(52,211,153,${lineOp})`;
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          });
        }
      });
    }

    function loop() {
      draw();
      animId = requestAnimationFrame(loop);
    }

    // Only animate on hover
    let idleTimer: ReturnType<typeof setTimeout>;
    section.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;

      if (isIdle) {
        isIdle = false;
        loop();
      }
      clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        isIdle = true;
        cancelAnimationFrame(animId);
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        mouse = { x: -9999, y: -9999 };
      }, 300);
    }, { passive: true });

    section.addEventListener('mouseleave', () => {
      mouse = { x: -9999, y: -9999 };
      clearTimeout(idleTimer);
      idleTimer = setTimeout(() => {
        isIdle = true;
        cancelAnimationFrame(animId);
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }, 200);
    });

    window.addEventListener('resize', resize, { passive: true });
    resize();
  })();


  // ─────────────────────────────────────────────────────────────────
  // §5b · DEPLOYMENTS — metric micro-bar fill (value-mapped)
  // ─────────────────────────────────────────────────────────────────
  document.querySelectorAll('.proof-card').forEach((card) => {
    const bar = card.querySelector('.metric-bar-fill') as HTMLElement;
    if (!bar) return;

    const style = bar.getAttribute('style') || '';
    const match = style.match(/--bar-w:\s*([\d.]+)/);
    if (!match) return;
    const pct = parseFloat(match[1]);

    gsap.to(bar, {
      width: pct + '%',
      duration: 1.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: card,
        start: 'top 80%',
        toggleActions: 'play none none none',
        invalidateOnRefresh: true,
      }
    });
  });

  // Metric-only hover glow (not whole card)
  document.querySelectorAll('.proof-card .metric-bar-bg').forEach((barBg) => {
    const parent = barBg.closest('.proof-card') as HTMLElement;
    if (!parent) return;
    parent.addEventListener('mouseenter', () => {
      gsap.to(barBg, { opacity: 1, duration: 0.2 });
    });
    parent.addEventListener('mouseleave', () => {
      gsap.to(barBg, { opacity: 0.6, duration: 0.3 });
    });
  });

  // ─────────────────────────────────────────────────────────────────
  // §6 · CONTACT CTA — slide in
  // ─────────────────────────────────────────────────────────────────
  gsap.to('.contact-card', {
    opacity: 1,
    y: 0,
    duration: 0.9,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '.contact-section',
      start: 'top 65%',
      toggleActions: 'play none none none',
      invalidateOnRefresh: true,
    }
  });
</script>
