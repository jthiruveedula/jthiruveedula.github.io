  .cap-card-inner:hover {
    box-shadow: 0 16px 48px -20px rgba(99,102,241,0.15);
  }

  .cap-icon-wrap {
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .capability-card:hover .cap-icon-wrap {
    transform: translateY(-2px);
    border-color: rgba(129,140,248,0.35);
  }
  .capability-card:hover .cap-icon {
    stroke: #a5b4fc;
  }

    @media (prefers-reduced-motion: reduce) {
    .pulse-ring,
    .scroll-line {
      animation: none;
    }
    .hero-line,
    .hero-description,
    .hero-tags,
    .hero-ctas {
      opacity: 1 !important;
      transform: none !important;
    }
    .exp-card-inner,
    .cap-card-inner {
      transition: none !important;
    }
    .exp-card-inner:hover,
    .cap-card-inner:hover {
      transform: none !important;
      box-shadow: none !important;
    }
    .metric-bar-fill { width: calc(var(--bar-w, 0) * 1%) !important; }
    .rail-fill-line { height: 100% !important; }
    .pipeline-step { opacity: 1 !important; transform: none !important; }
    .tension-diagram { opacity: 1 !important; transform: none !important; }
    .demo-box, .prod-box, .demo-prod-arrow { opacity: 1 !important; transform: none !important; }
    .phase-indicator { opacity: 1 !important; }
    .session-step { opacity: 1 !important; transform: none !important; }
    /* TENSION SVG final state (resolution) for reduced motion */
    .chaos-paths, .chaos-dots, .source-pulse-ring { opacity: 0 !important; }
    .gov-layer, .clean-paths { opacity: 1 !important; }
    .clean-p { stroke-dashoffset: 0 !important; }
    .clean-data-dot { opacity: 1 !important; }
    .source-node { stroke: #34d399 !important; }
    .tension-sources text { fill: #34d399 !important; }
    .target-pulse-ring { opacity: 0.4 !important; }
    .gov-scan-line, .grid-highlights { opacity: 0 !important; }
    .gov-glow { opacity: 0.08 !important; }
